# Secrets and machine-local values
# Keep shared model/provider/profile defaults in config.yaml/config.yml/config.json.
# Databricks profiles use the host/base URL from env via config `host_env`
# or `base_url_env`, so keep the endpoint here rather than hard-coding it in YAML.

COHERE_API_KEY=your_cohere_api_key
GEMINI_API_KEY=your_gemini_api_key
DATABRICKS_HOST=your-workspace-host.databricks.com
DATABRICKS_TOKEN=your_databricks_token


# Config discovery override (optional)
# RAG_TAG_CONFIG=./config.local.yaml

# Observability (optional)
# LOGFIRE_TOKEN must be a WRITE token (not read token) for ingestion.
# Read tokens are for query API only and will cause 401 errors.
# Alternative: Run 'logfire auth' to authenticate without setting token in .env
# LOGFIRE_PROJECT_NAME=your-project-name  # optional
LOGFIRE_TOKEN=your-write-logfire-token

# Neo4j (optional, recommended for Eureka/local self-managed runs)
# Set `defaults.graph_backend: neo4j` in config.yaml to activate the Neo4j runtime path.
# For Eureka architecture 1, keep Neo4j in the same session and point the app
# at localhost using the existing repo integration:
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=ragtag-dev-password
# NEO4J_DATABASE=neo4j
#
# Helper script settings for scripts/run_eureka.sh:
# NEO4J_HOME=$HOME/apps/neo4j
# NEO4J_DATA_DIR=$HOME/project-data/neo4j-data
# NEO4J_LOGS_DIR=$HOME/project-data/neo4j-logs

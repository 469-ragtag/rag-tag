# Secrets and machine-local values
# Keep shared model/provider/profile defaults in config.yaml/config.yml/config.json.
COHERE_API_KEY=your_cohere_api_key
GEMINI_API_KEY=your_gemini_api_key
DATABRICKS_HOST=your-workspace-host.databricks.com
DATABRICKS_TOKEN=your_databricks_token
LOGFIRE_TOKEN=your-write-logfire-token

# Databricks profiles use the host/base URL from env via config `host_env`
# or `base_url_env`, so keep the endpoint here rather than hard-coding it in YAML.

# Note: COHERE_API_KEY is automatically mapped to CO_API_KEY for PydanticAI compatibility

# Config discovery override (optional)
# RAG_TAG_CONFIG=./config.local.yaml

# Profile selection overrides (optional)
# ROUTER_PROFILE=router-gemini-flash
# AGENT_PROFILE=dbx-claude-sonnet-4-6

# Direct model overrides for one-off runs (optional)
# These bypass config-selected profiles.
# Note: Use 'google-gla' for AI Studio or 'google-vertex' for Vertex AI.
# ROUTER_MODEL=google-gla:gemini-2.5-flash
# AGENT_MODEL=cohere:command-a-03-2025

# Router mode: rule | llm (optional)
# ROUTER_MODE=llm

# Graph payload mode: full | minimal (optional; defaults to full)
# - full    (default): store complete parsed JSONL record in each graph node's
#            payload, including PropertySets, Quantities, and Geometry blocks.
#            Use this for full dotted-key filter support without a DB.
# - minimal: store only GlobalId, ExpressId, IfcType, ClassRaw, and Name in
#            each node's payload.  Reduces in-memory graph size significantly.
#            Dotted pset filters (e.g. Pset_WallCommon.FireRating) still work
#            when a SQLite DB is wired into the graph context via --db.
# GRAPH_PAYLOAD_MODE=full

# Observability (optional)
# LOGFIRE_TOKEN must be a WRITE token (not read token) for ingestion.
# Read tokens are for query API only and will cause 401 errors.
# Alternative: Run 'logfire auth' to authenticate without setting token in .env
# LOGFIRE_TOKEN=your-write-logfire-token
# LOGFIRE_PROJECT_NAME=your-project-name  # optional

# Legacy provider/model vars (DEPRECATED - prefer config profiles instead)
# These are kept for backward compatibility but will be removed in a future version.
# LLM_PROVIDER=gemini
# ROUTER_PROVIDER=gemini
# AGENT_PROVIDER=cohere
# GEMINI_MODEL=gemini-2.5-flash
# COHERE_MODEL=command-a-03-2025
